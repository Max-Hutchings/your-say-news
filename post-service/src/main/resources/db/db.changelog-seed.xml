<?xml version="1.0" encoding="UTF-8"?>
<!-- Seed / test data ONLY. No schema changes here.
     Run by the dedicated seeding container on `docker compose up` (not by the app at start). -->
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">
    <includeAll path="user-seeding" relativeToChangelogFile="true"/>
    <includeAll path="seeding" relativeToChangelogFile="true"/>
</databaseChangeLog>
