<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="0009-create-agent-generation-job-1" author="codex">
        <createTable tableName="agent_generation_job">
            <column name="id" type="uuid">
                <constraints primaryKey="true" primaryKeyName="pk_agent_generation_job" nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="request" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="attempt_count" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="next_attempt_at" type="timestamp with time zone"/>
            <column name="model" type="varchar(128)"/>
            <column name="provider_response_id" type="varchar(128)"/>
            <column name="draft" type="jsonb"/>
            <column name="error_code" type="varchar(64)"/>
            <column name="error_message" type="varchar(512)"/>
            <column name="published_post_id" type="bigint"/>
            <column name="created_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="started_at" type="timestamp with time zone"/>
            <column name="completed_at" type="timestamp with time zone"/>
        </createTable>

        <sql>
            ALTER TABLE agent_generation_job
                ADD CONSTRAINT ck_agent_generation_job_status
                    CHECK (status IN ('PENDING', 'RESEARCHING', 'DRAFT_READY', 'FAILED', 'PUBLISHED')),
                ADD CONSTRAINT ck_agent_generation_job_attempt_count
                    CHECK (attempt_count BETWEEN 0 AND 3)
        </sql>
        <createIndex tableName="agent_generation_job" indexName="ix_agent_job_status_retry">
            <column name="status"/>
            <column name="next_attempt_at"/>
        </createIndex>
        <createIndex tableName="agent_generation_job" indexName="ix_agent_job_user_created">
            <column name="user_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
