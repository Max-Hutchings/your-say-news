<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="0003-create-vote-1" author="mhutc">
        <createTable tableName="votes">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_votes"/>
            </column>
            <column name="post_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="vote_for" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="characteristic_snapshot" type="JSONB"/>
        </createTable>

        <!-- One vote per user per post: prevents double-voting and anchors PII isolation
             (a user_id appears at most once per post, so aggregation is always distinct). -->
        <addUniqueConstraint
                tableName="votes"
                columnNames="post_id, user_id"
                constraintName="uk_votes_post_user"/>
    </changeSet>

</databaseChangeLog>
