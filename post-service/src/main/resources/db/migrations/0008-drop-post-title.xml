<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="0008-drop-post-title-1" author="codex">
        <preConditions onFail="HALT">
            <columnExists tableName="post" columnName="title"/>
        </preConditions>
        <comment>The support question is now the post's sole primary heading.</comment>
        <dropColumn tableName="post" columnName="title"/>
    </changeSet>
</databaseChangeLog>
